[Unit]
Description=SunShine Go backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/sunshine/my-backend
ExecStart=/opt/sunshine/my-backend/sunshine-backend
Restart=always
RestartSec=3

# 生产环境把真实配置放在 .env，代码启动时也会读取这个文件。
# 这里额外让 systemd 读取一遍，方便以后排查服务环境变量。
EnvironmentFile=/opt/sunshine/my-backend/.env

[Install]
WantedBy=multi-user.target

