# token 签名密钥。上线必须改成足够长、不可猜的随机字符串。
APP_TOKEN_SECRET=please-change-to-a-long-random-production-secret

# 线上前端来源。启用 HTTPS 后填写你的正式域名。
CORS_ALLOWED_ORIGIN=https://example.com

# 首次启动时创建的超级管理员。使用全新数据库时会按这里生成。
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=please-change-this-password

# 邮箱验证码发送配置。SMTP_PASS 填 QQ 邮箱授权码，不是 QQ 登录密码。
SMTP_USER=2672172829@qq.com
SMTP_PASS=please-fill-your-qq-mail-auth-code
SMTP_HOST=smtp.qq.com
SMTP_PORT=587

