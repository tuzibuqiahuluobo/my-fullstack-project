# token 签名密钥。开发可以先用默认值，上线必须改成随机长字符串。
APP_TOKEN_SECRET=please-change-to-a-long-random-secret

# 允许访问后端的前端地址。本地 Vite 默认是 http://localhost:5173。
CORS_ALLOWED_ORIGIN=http://localhost:5173

# 首次启动时自动创建的超级管理员账号。
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=please-change-this-password

# 邮件验证码配置。留空时，验证码会打印在后端控制台，方便本地学习调试。
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
