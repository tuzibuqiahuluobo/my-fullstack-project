# token 签名密钥。开发可以先用默认值，上线必须改成随机长字符串。
APP_TOKEN_SECRET=please-change-to-a-long-random-secret

# 允许访问后端的前端地址。本地 Vite 默认是 http://localhost:5173。
CORS_ALLOWED_ORIGIN=http://localhost:5173

# 首次启动时自动创建的超级管理员账号。
SUPER_ADMIN_USERNAME=账户名
SUPER_ADMIN_EMAIL=邮箱
SUPER_ADMIN_PASSWORD=密码

# 邮件验证码配置。复制本文件为 .env 后，把 SMTP_PASS 改成你自己的 QQ 邮箱授权码。
SMTP_USER=2672172829@qq.com
SMTP_PASS=你的QQ邮箱授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
